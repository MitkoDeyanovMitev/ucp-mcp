{
  "repositories": [
    {
      "name": "ucp-mcp-internal",
      "type": "local",
      "path": "./src",
      "include": ["**/*.js", "**/*.py", "**/*.md"],
      "enabled": false
    },
    {
      "name": "ucp",
      "type": "git",
      "url": "https://github.com/Universal-Commerce-Protocol/ucp.git",
      "branch": "gh-pages",
      "include": ["**/*.md", "**/*.html", "**/*.txt", "**/*.json"],
      "exclude": [
        "**/assets/**",
        "**/stylesheets/**",
        "**/javascripts/**",
        "**/search/**",
        "**/*.min.js",
        "**/*.min.css",
        "**/sitemap.xml"
      ],
      "enabled": true
    },
    {
      "name": "samples",
      "type": "git",
      "url": "https://github.com/Universal-Commerce-Protocol/samples.git",
      "branch": "main",
      "include": ["**/*.js", "**/*.py", "**/*.ts", "**/*.md", "**/*.json"],
      "exclude": [
        "**/node_modules/**",
        "**/.venv/**",
        "**/dist/**",
        "**/build/**"
      ],
      "enabled": false
    },
    {
      "name": "python-sdk",
      "type": "git",
      "url": "https://github.com/Universal-Commerce-Protocol/python-sdk.git",
      "branch": "main",
      "include": ["**/*.py", "**/*.md"],
      "exclude": ["**/tests/**", "**/venv/**", "**/*.test.py"],
      "enabled": true
    },
    {
      "name": "js-sdk",
      "type": "git",
      "url": "https://github.com/Universal-Commerce-Protocol/js-sdk.git",
      "branch": "main",
      "include": ["**/*.js", "**/*.ts", "**/*.md"],
      "exclude": [
        "**/node_modules/**",
        "**/test/**",
        "**/*.test.ts",
        "**/dist/**"
      ],
      "enabled": true
    },
    {
      "name": "conformance",
      "type": "git",
      "url": "https://github.com/Universal-Commerce-Protocol/conformance.git",
      "branch": "main",
      "include": ["**/*.md", "**/*.json", "**/*.yaml", "**/*.yml"],
      "exclude": ["**/test_data/**", "**/.github/**"],
      "enabled": false
    },
    {
      "name": "ucp-schema",
      "type": "git",
      "url": "https://github.com/Universal-Commerce-Protocol/ucp-schema.git",
      "branch": "main",
      "include": ["**/*.json", "**/*.yaml", "**/*.yml", "**/*.md"],
      "exclude": ["**/.github/**", "**/tests/**", "**/*.example.json"],
      "enabled": true
    }
  ]
}
